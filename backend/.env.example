# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/yunduan

# JWT 配置
JWT_SECRET_KEY=replace_me
SECRET_ENCRYPTION_KEY=replace_me
PASSWORD_PEPPER=replace_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_COOKIE_NAME=yunduan_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
ALLOW_PUBLIC_REGISTRATION=true
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_REQUEST_COOLDOWN_SECONDS=60
# 生产环境请改成浏览器真实访问前端的公网地址，例如 https://example.com 或 http://<server-ip>
PUBLIC_APP_URL=http://localhost:5173
# SMTP 发信配置，用于“忘记密码 -> 邮件重置”链路
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=云端检测系统
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# CORS 配置
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# COS 配置
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_BUCKET=
COS_PUBLIC_BASE_URL=
COS_SIGNED_URL_EXPIRE_SECONDS=3600

# 默认管理员
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change_me_admin_password
DEFAULT_ADMIN_DISPLAY_NAME=系统管理员
DEFAULT_ADMIN_EMAIL=admin@example.com
